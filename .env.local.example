# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (server-only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider — used for AI table suggestions (any OpenAI-compatible API).
#
# FREE option (recommended): Groq — open-source Llama models, no billing required.
#   Get a key at https://console.groq.com/keys
#   OPENAI_API_KEY=gsk_...
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.3-70b-versatile
#
# OpenAI option:
#   OPENAI_API_KEY=sk-...
#   (leave OPENAI_BASE_URL blank)
#   OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
